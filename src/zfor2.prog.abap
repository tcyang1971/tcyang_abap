*&---------------------------------------------------------------------*
*& Report zfor2
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
REPORT zfor2.

DATA(lv_sum) = REDUCE i(
    INIT lv_s = 0
    FOR lv_i = 1 THEN lv_i + 1 UNTIL lv_i > 5
    NEXT lv_s  = lv_s +  lv_i
).

WRITE: / |使用 FOR 與 REDUCE 計算結果：{ lv_sum }|.
